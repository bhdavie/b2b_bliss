# Copy to .env and fill in. Loaded by docker-compose.

# --- Postgres ---
POSTGRES_USER=bliss
POSTGRES_PASSWORD=bliss_dev
POSTGRES_DB=bliss

# --- Backend (read by config.yml via ${VAR:-default} substitution) ---
# JWT signing key. Must be at least 32 chars in dev. Generate a real value for staging/prod.
BLISS_JWT_SECRET=dev-secret-change-me-dev-secret-change-me
# Sentry DSN. Leave blank in local dev to disable.
BLISS_SENTRY_DSN=
# Environment label (development, staging, production)
BLISS_ENV=development

# --- Frontend ---
# Public URL of the backend, called from server components and client.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
# Sentry DSN for the frontend. Leave blank to disable.
NEXT_PUBLIC_SENTRY_DSN=
